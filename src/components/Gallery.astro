---
import g1 from '../assets/g1.jpg';
import g2 from '../assets/g2.jpg';
import g3 from '../assets/g3.jpg';
import g4 from '../assets/g4.jpg';
---
<section id="gallery" class="py-28 md:py-36 px-6">
  <div class="max-w-6xl mx-auto">
    <p class="section-tag reveal">Recuerdos</p>
    <span class="gold-line reveal"></span>
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-12 reveal">
      <h2 class="section-title">Galería</h2>
      <a href="https://www.instagram.com/omarvizuete" target="_blank" rel="noopener noreferrer"
         class="btn-outline inline-flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        Ver en Instagram
      </a>
    </div>

    <!-- Masonry-style grid: portrait | wide / two squares -->
    <div class="gallery-grid reveal-grid">

      <!-- g2: portrait of Omar — tall left column -->
      <div class="g-portrait gallery-item">
        <img src={g2.src} alt="Omar Vizuete en el escenario" loading="lazy"
             style="object-position: center 15%;" />
        <div class="gallery-overlay"></div>
      </div>

      <!-- g1: wide concert shot — top right -->
      <div class="g-wide gallery-item">
        <img src={g1.src} alt="Omar Vizuete ante miles de personas" loading="lazy"
             style="object-position: center 75%;" />
        <div class="gallery-overlay"></div>
      </div>

      <!-- g3: on stage with performer -->
      <div class="gallery-item">
        <img src={g3.src} alt="Omar Vizuete en tarima" loading="lazy"
             style="object-position: center 20%;" />
        <div class="gallery-overlay"></div>
      </div>

      <!-- g4: formal event -->
      <div class="gallery-item">
        <img src={g4.src} alt="Omar Vizuete en evento especial" loading="lazy"
             style="object-position: center 20%;" />
        <div class="gallery-overlay"></div>
      </div>

    </div>
  </div>
</section>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 340px 300px;
    gap: 8px;
  }

  /* Portrait: col 1, both rows */
  .g-portrait {
    grid-column: 1;
    grid-row: 1 / 3;
  }

  /* Wide concert: col 2-3, row 1 */
  .g-wide {
    grid-column: 2 / 4;
    grid-row: 1;
  }

  /* g3 and g4 auto-place in col 2 and 3 row 2 */

  @media (max-width: 700px) {
    .gallery-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
    }
    .g-portrait { grid-column: 1; grid-row: 1 / 3; }
    .g-wide     { grid-column: 2; grid-row: 1; }
  }

  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
    .g-portrait, .g-wide { grid-column: 1; grid-row: auto; }
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    border: 1px solid #1a1a1a;
    background: #111;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .gallery-item:hover img { transform: scale(1.06); }
  .gallery-item:hover { border-color: rgba(201,168,76,0.4); }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8,8,8,0.6) 0%, transparent 50%);
    pointer-events: none;
  }

  /* Staggered reveal for grid items */
  .reveal-grid .gallery-item {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal-grid.visible .gallery-item:nth-child(1) { opacity:1; transform:none; transition-delay: 0s; }
  .reveal-grid.visible .gallery-item:nth-child(2) { opacity:1; transform:none; transition-delay: 0.1s; }
  .reveal-grid.visible .gallery-item:nth-child(3) { opacity:1; transform:none; transition-delay: 0.2s; }
  .reveal-grid.visible .gallery-item:nth-child(4) { opacity:1; transform:none; transition-delay: 0.3s; }
</style>
