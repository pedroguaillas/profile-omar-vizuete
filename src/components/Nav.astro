---
---
<header id="nav" class="fixed top-0 left-0 right-0 z-50">
  <nav class="max-w-7xl mx-auto flex items-center justify-between px-6 py-5">
    <a href="#hero" class="text-white font-bold tracking-[0.12em] text-sm uppercase" style="font-family:'Inter',sans-serif;">
      OMAR <span style="color:#C9A84C">VIZUETE</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      <a href="#about"   class="nav-link">Sobre él</a>
      <a href="#music"   class="nav-link">Música</a>
      <a href="#gallery" class="nav-link">Galería</a>
      <a href="#contact" class="nav-link">Contacto</a>
    </div>

    <!-- Mobile hamburger (CSS-only toggle) -->
    <label for="menu-toggle" class="md:hidden cursor-pointer text-white">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <line x1="3" y1="6"  x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </label>
  </nav>

  <input type="checkbox" id="menu-toggle" class="hidden" />
  <div id="mobile-menu" class="md:hidden px-6 pb-4 border-t border-white/10" style="background:#080808;">
    <div class="flex flex-col gap-4 pt-4">
      <a href="#about"   class="nav-link" onclick="document.getElementById('menu-toggle').checked=false">Sobre él</a>
      <a href="#music"   class="nav-link" onclick="document.getElementById('menu-toggle').checked=false">Música</a>
      <a href="#gallery" class="nav-link" onclick="document.getElementById('menu-toggle').checked=false">Galería</a>
      <a href="#contact" class="nav-link" onclick="document.getElementById('menu-toggle').checked=false">Contacto</a>
    </div>
  </div>
</header>

<script>
  // Transparent → opaque on scroll
  const nav = document.getElementById('nav')!;
  const update = () => {
    nav.style.background = window.scrollY > 60
      ? 'rgba(8,8,8,0.97)'
      : 'transparent';
    nav.style.backdropFilter = window.scrollY > 60 ? 'blur(12px)' : 'none';
    nav.style.borderBottom = window.scrollY > 60 ? '1px solid rgba(255,255,255,0.06)' : 'none';
  };
  window.addEventListener('scroll', update, { passive: true });
  update();
</script>

<style>
  .nav-link {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9ca3af;
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-link:hover { color: #C9A84C; }

  #menu-toggle:checked ~ #mobile-menu { display: block; }
  #mobile-menu { display: none; }
</style>
