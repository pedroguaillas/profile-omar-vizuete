---
// TODO: replace with real YouTube video IDs
const featured = {
  title:       'Omar Vizuete — Video Oficial',
  youtubeId:   'dQw4w9WgXcQ', // replace with real ID
  description: 'El videoclip oficial de su más reciente sencillo.',
};

const moreVideos = [
  { title: 'Video en Vivo — Nombre del Evento', youtubeId: 'dQw4w9WgXcQ', year: '2024' },
  { title: 'Sesión Acústica',                   youtubeId: 'dQw4w9WgXcQ', year: '2023' },
  { title: 'Entrevista Exclusiva',              youtubeId: 'dQw4w9WgXcQ', year: '2023' },
];
---
<section id="videos" class="py-28 md:py-36 px-6">
  <div class="max-w-6xl mx-auto">
    <p class="section-tag">Contenido</p>
    <span class="gold-line"></span>
    <h2 class="section-title mb-12">Videos</h2>

    <!-- Featured video -->
    <div class="mb-8">
      <div class="video-wrapper">
        <iframe
          src={`https://www.youtube.com/embed/${featured.youtubeId}?rel=0&modestbranding=1`}
          title={featured.title}
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <p class="mt-4 text-white font-medium">{featured.title}</p>
      <p class="text-gray-500 text-sm mt-1">{featured.description}</p>
    </div>

    <!-- More videos grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-12">
      {moreVideos.map(v => (
        <a href={`https://www.youtube.com/watch?v=${v.youtubeId}`}
           target="_blank" rel="noopener noreferrer"
           class="video-card group">
          <div class="thumb-wrapper">
            <img
              src={`https://img.youtube.com/vi/${v.youtubeId}/mqdefault.jpg`}
              alt={v.title}
              loading="lazy"
            />
            <div class="thumb-overlay">
              <div class="play-circle">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#080808" viewBox="0 0 24 24">
                  <polygon points="5,3 19,12 5,21"/>
                </svg>
              </div>
            </div>
          </div>
          <div class="p-3">
            <p class="video-title">{v.title}</p>
            <p class="video-year">{v.year}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a href="https://www.youtube.com/@omarvizuete" target="_blank" rel="noopener noreferrer"
         class="btn-outline inline-flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
        </svg>
        Ver todos en YouTube
      </a>
    </div>
  </div>
</section>

<style>
  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background: #111;
    border: 1px solid #1a1a1a;
  }
  .video-wrapper iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
  }

  .video-card {
    display: block;
    background: #111;
    border: 1px solid #1a1a1a;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
    overflow: hidden;
  }
  .video-card:hover { border-color: #C9A84C; transform: translateY(-3px); }

  .thumb-wrapper { position: relative; overflow: hidden; aspect-ratio: 16/9; }
  .thumb-wrapper img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .thumb-overlay {
    position: absolute; inset: 0;
    background: rgba(8,8,8,0.5);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.2s;
  }
  .video-card:hover .thumb-overlay { opacity: 1; }
  .play-circle {
    width: 48px; height: 48px; border-radius: 50%;
    background: #C9A84C;
    display: flex; align-items: center; justify-content: center;
  }

  .video-title { font-size: 0.875rem; font-weight: 500; color: #e5e7eb; line-height: 1.3; }
  .video-year  { font-size: 0.7rem; color: #6b7280; margin-top: 4px; letter-spacing: 0.05em; }
</style>
