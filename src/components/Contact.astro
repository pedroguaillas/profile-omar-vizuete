---
// TODO: replace with real contact info
const WHATSAPP = '593999145920'; // número con código de país sin +
---
<section id="contact" class="py-28 md:py-36 px-6" style="background:#0c0c0c;">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-16">

      <!-- Left: info -->
      <div>
        <p class="section-tag reveal">Contacto</p>
        <span class="gold-line reveal"></span>
        <h2 class="section-title mb-6 reveal">Comparte<br><em style="color:#C9A84C;">tu recuerdo.</em></h2>
        <p class="text-gray-400 leading-relaxed mb-10 reveal">
          ¿Tienes un mensaje, recuerdo o fotografía de Omar? Escríbenos — cada palabra importa y honra su legado.
        </p>

        <div class="flex flex-col gap-4">
          <!-- WhatsApp -->
          <a href={`https://wa.me/${WHATSAPP}?text=Hola%20Sra.%20Gladys%2C%20quiero%20compartirle%20un%20recuerdo%20de%20Omar.`}
             target="_blank" rel="noopener noreferrer"
             class="contact-card contact-card--whatsapp reveal">
            <div class="contact-icon" style="background:rgba(37,211,102,0.1);border-color:rgba(37,211,102,0.2);">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#25D366" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
              </svg>
            </div>
            <div>
              <p class="contact-label">WhatsApp</p>
              <p class="contact-value">Escríbenos directamente</p>
            </div>
            <svg class="ml-auto" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:#4b5563;">
              <polyline points="9,18 15,12 9,6"/>
            </svg>
          </a>

          <!-- Instagram -->
          <a href="https://www.instagram.com/omarvizuete" target="_blank" rel="noopener noreferrer"
             class="contact-card reveal">
            <div class="contact-icon" style="background:rgba(225,48,108,0.1);border-color:rgba(225,48,108,0.2);">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#E1306C" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </div>
            <div>
              <p class="contact-label">Instagram</p>
              <p class="contact-value">@omarvizuete</p>
            </div>
            <svg class="ml-auto" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:#4b5563;">
              <polyline points="9,18 15,12 9,6"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: form -->
      <div>
        <form class="contact-form reveal" name="contact" method="POST" data-netlify="true">
          <input type="hidden" name="form-name" value="contact" />
          <div class="form-group">
            <label for="name">Nombre</label>
            <input type="text" id="name" name="name" placeholder="Tu nombre" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="tu@email.com" required />
          </div>
          <div class="form-group">
            <label for="phone">Teléfono / WhatsApp</label>
            <input type="tel" id="phone" name="phone" placeholder="+593..." />
          </div>
          <div class="form-group">
            <label for="event">Tipo de evento</label>
            <select id="event" name="event">
              <option value="">Selecciona...</option>
              <option>Mensaje de recuerdo</option>
              <option>Compartir fotografía</option>
              <option>Familia / Amigos cercanos</option>
              <option>Medios / Prensa</option>
              <option>Otro</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Mensaje</label>
            <textarea id="message" name="message" rows="4" placeholder="Comparte tu recuerdo, anécdota o mensaje para Omar..." required></textarea>
          </div>
          <button type="submit" class="btn-primary w-full justify-center">Enviar mensaje</button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid #1a1a1a;
    background: #111;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }
  .contact-card:hover { border-color: rgba(201,168,76,0.3); background: #161616; }
  .contact-card--whatsapp:hover { border-color: rgba(37,211,102,0.3); }

  .contact-icon {
    width: 44px; height: 44px;
    border-radius: 50%;
    border: 1px solid;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .contact-label { font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: #6b7280; }
  .contact-value { font-size: 0.9rem; color: #e5e7eb; margin-top: 2px; }

  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-group label { font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: #9ca3af; }

  .form-group input,
  .form-group select,
  .form-group textarea {
    background: #111;
    border: 1px solid #222;
    color: #fff;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    font-family: 'Inter', sans-serif;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
    resize: vertical;
    appearance: none;
  }
  .form-group input::placeholder,
  .form-group textarea::placeholder { color: #4b5563; }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus { border-color: #C9A84C; }

  .form-group select option { background: #111; }
</style>
